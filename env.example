# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub — it contains secrets!

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-long-random-secret-here-minimum-32-chars

# Railway auto-injects this when you add a PostgreSQL plugin
# Locally: leave as sqlite or create a local postgres
DATABASE_URL=sqlite:///./equitywalls.db

# Get from: https://rapidapi.com/apimaker/api/zillow-com1
ZILLOW_API_KEY=

# Polygon RPC (free public node works fine)
POLYGON_RPC=https://polygon-rpc.com
